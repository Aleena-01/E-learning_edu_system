<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/certificateRoot"
    android:layout_width="800dp"
    android:layout_height="600dp"
    android:background="@color/white"
    android:padding="2dp">

    <!-- Elegant Border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/certificate_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="60dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CERTIFICATE"
            android:textColor="@color/primary_blue"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="OF COMPLETION"
            android:textColor="@color/primary_dark"
            android:textSize="22sp"
            android:letterSpacing="0.2" />

        <View
            android:layout_width="150dp"
            android:layout_height="2dp"
            android:layout_marginTop="30dp"
            android:background="@color/secondary_teal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="This is to certify that"
            android:textColor="@color/text_sub"
            android:textSize="18sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvCertStudentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Student Name"
            android:textColor="@color/text_main"
            android:textSize="42sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="has successfully completed the course"
            android:textColor="@color/text_sub"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvCertCourseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Course Title"
            android:textColor="@color/primary_blue"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View android:layout_width="120dp" android:layout_height="1dp" android:background="@color/gray" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:alpha="0.3"
                android:contentDescription="Certificate Seal" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <View android:layout_width="120dp" android:layout_height="1dp" android:background="@color/gray" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Instructor" android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
