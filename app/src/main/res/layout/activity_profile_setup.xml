<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete Your Profile"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tell us more about your background"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp"/>

        <!-- Teacher Specific Fields -->
        <LinearLayout
            android:id="@+id/llTeacherFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etQualification"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Qualification (e.g. Master's in CS)"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_white"
                android:paddingStart="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etExperience"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Experience (e.g. 5 Years)"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_white"
                android:paddingStart="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etExpertise"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Expertise Field (e.g. Android Development)"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_white"
                android:paddingStart="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"/>
        </LinearLayout>

        <!-- Student Specific Fields -->
        <LinearLayout
            android:id="@+id/llStudentFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/etEducationLevel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Education Level (e.g. Undergraduate)"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_white"
                android:paddingStart="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"/>

            <EditText
                android:id="@+id/etInterests"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Interests (comma separated)"
                android:gravity="top"
                android:padding="16dp"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_white"
                android:layout_marginBottom="16dp"
                android:elevation="2dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etBio"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Tell us about yourself..."
            android:gravity="top"
            android:padding="16dp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_white"
            android:layout_marginBottom="32dp"
            android:elevation="2dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCompleteSignup"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Finish Registration"
            android:background="@drawable/rounded_button"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:elevation="4dp"/>

    </LinearLayout>
</ScrollView>
