<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvAsgnTitleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assignment Submission"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvAsgnDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Please upload your assignment solution here."
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/tvAsgnTitleLabel" />

    <Button
        android:id="@+id/btnUploadFile"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="@color/gray"
        android:text="Upload File"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/tvAsgnDesc" />

    <Button
        android:id="@+id/btnSubmitAsgn"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/rounded_button"
        android:text="Submit Assignment"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/btnUploadFile" />

</androidx.constraintlayout.widget.ConstraintLayout>