<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvAddCourseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create New Course"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="32dp"/>

        <EditText
            android:id="@+id/etCourseTitle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Course Title"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_white"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <EditText
            android:id="@+id/etCourseDesc"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="Course Description"
            android:gravity="top"
            android:padding="16dp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_white"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <EditText
            android:id="@+id/etCourseCategory"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Category (e.g. Programming)"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_white"
            android:paddingStart="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"/>

        <EditText
            android:id="@+id/etCourseDuration"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Duration (e.g. 4 Weeks)"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_white"
            android:paddingStart="16dp"
            android:layout_marginBottom="32dp"
            android:elevation="2dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveCourse"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Save Course"
            android:background="@drawable/rounded_button"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:elevation="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancelCourse"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="Cancel"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/text_hint"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:elevation="2dp"/>

    </LinearLayout>
</ScrollView>