<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvAddCourseTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Add New Course"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etCourseTitle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="@color/white"
        android:hint="Course Title"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tvAddCourseTitle" />

    <EditText
        android:id="@+id/etCourseDesc"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="@color/white"
        android:gravity="top"
        android:hint="Course Description"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@+id/etCourseTitle" />

    <EditText
        android:id="@+id/etCourseCategory"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="@color/white"
        android:hint="Category (e.g. Programming)"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@+id/etCourseDesc" />

    <EditText
        android:id="@+id/etVideoUrl"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/rounded_button"
        android:backgroundTint="@color/white"
        android:hint="Video URL (YouTube)"
        android:paddingStart="16dp"
        app:layout_constraintTop_toBottomOf="@+id/etCourseCategory" />

    <Button
        android:id="@+id/btnSaveCourse"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/rounded_button"
        android:text="Save Course"
        android:textAllCaps="false"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@+id/etVideoUrl" />

</androidx.constraintlayout.widget.ConstraintLayout>